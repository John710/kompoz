# PostgreSQL
# PostgreSQL user name (default: kompoz)
POSTGRES_USER=kompoz
# PostgreSQL password for the kompoz user (required — must be filled in)
POSTGRES_PASSWORD=
# PostgreSQL database name (default: kompoz)
POSTGRES_DB=kompoz
# PostgreSQL connection URL, e.g. postgres://kompoz:password@db:5432/kompoz
DATABASE_URL=

# App settings
# Port on which the kompoz web server listens (default: 3710)
PORT=3710
# System timezone for containers (default: UTC)
TZ=UTC
# Comma-separated list of host paths mounted into the kompoz container
COMPOSE_MOUNTS=/mnt/docker,/mnt/server
# Root directory for compose files inside the container (default: /compose)
COMPOSE_ROOT=/compose
# Status check interval in milliseconds (default: 60000)
STATUS_CHECK_INTERVAL=60000

# Auth
# Basic-auth username for the web UI
AUTH_USER=
# Basic-auth password for the web UI
AUTH_PASS=
# Secret key used for JWT/cookie signing (must be filled in)
AUTH_SECRET=
# Set to "true" to allow new user registration (requires DATABASE_URL)
AUTH_ALLOW_REGISTER=

# Security
# Set to "true" to enforce HTTPS-only cookies
COOKIE_SECURE=
# Comma-separated whitelist of allowed file extensions (e.g. .yml,.yaml,.json)
FILE_EXT_WHITELIST=
# Set to "true" to allow all file extensions without restriction
ALLOW_ALL_EXTENSIONS=
